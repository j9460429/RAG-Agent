# ============================================================
# NexusMind - 環境變數範本
# 複製此檔案為 .env.production 並填入實際值
# ============================================================

# ---- Supabase ----
# 從 Supabase Dashboard → Project Settings → API 取得
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Server-side Supabase URL（容器內部，通常與 NEXT_PUBLIC_SUPABASE_URL 相同）
SUPABASE_SERVER_URL=https://YOUR_PROJECT_REF.supabase.co

# ---- Google Gemini AI ----
# 從 Google AI Studio (aistudio.google.com) 取得
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key_here

# ---- Google OAuth（可選，Drive 整合用）----
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
USE_OAUTH=false

# ---- 微服務內部 URL（Docker 網路，勿修改）----
MARKER_SERVICE_URL=http://marker:8001
LIGHTRAG_SERVICE_URL=http://lightrag:8002
SKILL_EXECUTOR_URL=http://skill-executor:8003

# ---- Telegram Bot（可選）----
# 從 @BotFather 取得 Bot Token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 加密金鑰：使用 openssl rand -hex 32 生成（必須 64 位十六進位字元）
BOT_TOKEN_ENCRYPTION_KEY=your_64_char_hex_key_here
K_MASTER_KEY=your_64_char_hex_key_here

# Cron Job 保護金鑰：使用 openssl rand -hex 32 生成
CRON_SECRET=your_cron_secret_here

# 內部 API 金鑰：使用 openssl rand -hex 32 生成
INTERNAL_API_KEY=your_internal_api_key_here

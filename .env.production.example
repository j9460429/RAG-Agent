# ============================
# NexusMind NAS Docker 部署環境變數
# ============================
# 複製此檔案為 .env.production 並填入實際值
# cp .env.production.example .env.production

# ---- Supabase ----
# 使用雲端 Supabase 或自建 Supabase 的 URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- AI API Keys ----
GOOGLE_GENERATIVE_AI_API_KEY=your-google-api-key

# ---- Google OAuth（從 Google Cloud Console 設定） ----
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=https://your-domain.com/api/gdrive/callback
USE_OAUTH=false

# ---- 微服務（Docker 內部網路，不需修改） ----
MARKER_SERVICE_URL=http://marker:8001
LIGHTRAG_SERVICE_URL=http://lightrag:8002



# ---- Cron / 定時任務 ----
# NAS Task Scheduler 呼叫 /api/cron/check-sources 時的驗證密鑰
CRON_SECRET=your-cron-secret


